// ======================================================
// HANDLE ROOT PAGE
// ======================================================

void handleRoot() {
  server.send(200, "text/html", webpage());
}

// ======================================================
// SETUP
// ======================================================

void setup() {

  Serial.begin(115200);

  pinMode(RAIN_SENSOR, INPUT);
  pinMode(FIRE_SENSOR, INPUT);
  pinMode(IR_SENSOR, INPUT);

  pinMode(BUZZER, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  dht.begin();

  servoMotor.attach(SERVO_PIN);
  servoMotor.write(0);

  // OLED
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED Failed");
    while(1);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(WHITE);

  display.setCursor(0,20);
  display.println("CONNECTING");

  display.display();

  // WIFI CONNECT
  WiFi.begin(ssid, password);

  while(WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("");
  Serial.println("WiFi Connected");

  // SHOW IP ADDRESS
  Serial.println(WiFi.localIP());

  display.clearDisplay();

  display.setTextSize(1);

  display.setCursor(0,0);
  display.println("WiFi Connected");

  display.setCursor(0,20);
  display.println(WiFi.localIP());

  display.display();

  delay(5000);

  // WEB SERVER
  server.on("/", handleRoot);

  server.begin();

  Serial.println("Server Started");
}

// ======================================================
// LOOP
// ======================================================

void loop() {

  // ================= READ SENSORS =================

  soilValue = analogRead(SOIL_SENSOR);

  rainValue = digitalRead(RAIN_SENSOR);

  fireValue = digitalRead(FIRE_SENSOR);

  irValue = digitalRead(IR_SENSOR);

  temperature = dht.readTemperature();

  humidity = dht.readHumidity();

  // ================= ULTRASONIC =================

  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  duration = pulseIn(ECHO_PIN, HIGH);

  distance = duration * 0.034 / 2;

  // ================= SERVO =================

  if(soilValue > 2500) {
    servoMotor.write(90);
  }
  else {
    servoMotor.write(0);
  }

  // ================= BUZZER =================

  if(fireValue == LOW || irValue == LOW || distance > 20) {
    digitalWrite(BUZZER, HIGH);
  }
  else {
    digitalWrite(BUZZER, LOW);
  }

  // ================= OLED DISPLAY =================

  display.clearDisplay();

  display.setTextSize(1);

  display.setCursor(0,0);
  display.print("Temp:");
  display.print(temperature);

  display.setCursor(0,10);
  display.print("Hum:");
  display.print(humidity);

  display.setCursor(0,20);
  display.print("Soil:");
  display.print(soilValue);

  display.setCursor(0,30);
  display.print("Water:");
  display.print(distance);

  display.setCursor(0,40);

  if(fireValue == LOW)
    display.println("FIRE DETECTED");

  else if(irValue == LOW)
    display.println("ANIMAL DETECTED");

  else if(rainValue == LOW)
    display.println("RAIN DETECTED");

  else
    display.println("SYSTEM NORMAL");

  display.display();

  // ================= HANDLE WEB =================

  server.handleClient();

  delay(1000);
}
